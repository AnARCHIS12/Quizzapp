# Quizzapp Environment Variables Configuration Template
# Copy this file to .env and configure accordingly.

# 1. Database Connections
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=quizzapp
DB_USER=root
DB_PASS=

# 2. WebSocket Configuration
# Port must match WS_PORT in client scripts (e.g. 8080)
WS_PORT=8080

# 3. JWT Core Security Salt
JWT_SECRET=quizzapp_super_secret_jwt_key_2026_change_me

# 4. SMTP Email Dispatch Setup
# If SMTP_HOST is left empty, the application falls back to localized logging in logs/mail.log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
MAIL_FROM_ADDRESS=no-reply@quizapp.local
MAIL_FROM_NAME=Quizzapp
SMTP_ALLOW_SELF_SIGNED=false

# 5. Mistral AI Integration
# Leave empty to use offline database seeding questions.
# Set MISTRAL_API_KEY to activate dynamic "never identical" question generation.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# 6. Docker Registry Image Config (for build & push commands)
# DOCKER_IMAGE_PHP=votre-pseudo-dockerhub/quizzapp-php:latest
# DOCKER_IMAGE_WS=votre-pseudo-dockerhub/quizzapp-websocket:latest
